# ============================================================
# Rubble — Environment Configuration
# ============================================================
# Local (USBWebserver): DB_HOST=localhost
# Docker Compose:       DB_HOST=db
# ============================================================

DB_HOST=localhost
DB_NAME=manutencao
DB_USER=
DB_PASS=

# Required only for Docker Compose (mariadb root password)
# DB_ROOT_PASSWORD=

# Let's Encrypt registration email (Docker only, used in docker-compose.yml)
LE_EMAIL=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Rubble

NOTIFY_EMAILS=

# PV Email — destinatários Para (To)
#PV_EMAILS_ES=
#PV_EMAILS_RJ=
# PV Email — destinatários em Cópia (Cc)
#PV_EMAILS_ES_CC=
#PV_EMAILS_RJ_CC=

# Cloudflare Turnstile (login protection — leave empty to skip in dev)
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

JWT_SECRET=<64-char-random-hex>

APP_DEBUG=false
# Local (USBWebserver): ALLOWED_ORIGINS=* (APP_DEBUG=true aceita wildcard)
# Docker/Produção:      ALLOWED_ORIGINS=https://rubbleapp.duckdns.org (APP_DEBUG=false rejeita *)
ALLOWED_ORIGINS=*
